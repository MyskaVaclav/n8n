    {
      "parameters": {
        "jsCode": "// --- 1) Map elementId -> base name (uprav si jak chceš)\nconst ID_TO_NAME = {\n  23757: \"cell_voltage_min_v\",\n  23758: \"cell_voltage_max_v\",\n  23759: \"cell_temp_min_c\",\n  23760: \"cell_temp_max_c\",\n  23761: \"module_voltage_min_v\",\n  23762: \"module_voltage_max_v\",\n  23763: \"module_temp_max_c\",\n  23764: \"module_temp_min_c\",\n  23765: \"soc_pct\",\n  23766: \"soe_kwh\",\n  23767: \"dc_voltage_v\",\n  23768: \"dc_current_a\",\n\n  23769: \"cell_id_max_temp\",\n  23770: \"cell_id_min_temp\",\n  23771: \"module_id_max_temp\",\n  23772: \"module_id_min_temp\",\n  23773: \"cell_id_max_voltage\",\n  23774: \"cell_id_min_voltage\",\n  23775: \"module_id_max_voltage\",\n  23776: \"module_id_min_voltage\",\n};\n\n// --- 2) n8n někdy balí response do array [ { ... } ]\nconst r = Array.isArray(items[0].json) ? items[0].json[0] : items[0].json;\n\nconst labels = r.labelsData;\nconst dict = r.dictData;\n\nif (!labels || !Array.isArray(labels)) throw new Error(\"labelsData missing\");\nif (!dict || typeof dict !== \"object\") throw new Error(\"dictData missing\");\n\n// --- 3) Helper: parse \"el_23761_avg\" -> { id:23761, agg:'avg' }\nfunction parseKey(key) {\n  const m = key.match(/^el_(\\d+)_(\\w+)$/);\n  if (!m) return null;\n  return { elementId: Number(m[1]), agg: m[2] };\n}\n\n// --- 4) Build column list + accessors\nconst seriesKeys = Object.keys(dict);\n\n// Map to output column names\nconst colNames = seriesKeys.map(k => {\n  const parsed = parseKey(k);\n  if (!parsed) return k; // fallback\n  const base = ID_TO_NAME[parsed.elementId] ?? `element_${parsed.elementId}`;\n  return `${base}_${parsed.agg}`; // e.g. module_voltage_min_v_avg\n});\n\n// --- 5) Create rows: one row per timestamp\n// labels are unix ms timestamps -> ISO\nconst rows = [];\n\nfor (let i = 0; i < labels.length; i++) {\n  const ts = labels[i];\n  const row = { time: new Date(ts).toISOString() };\n\n  for (let s = 0; s < seriesKeys.length; s++) {\n    const key = seriesKeys[s];\n    const col = colNames[s];\n    const arr = dict[key];\n\n    // Some series might be shorter; guard it\n    row[col] = Array.isArray(arr) ? (arr[i] ?? null) : null;\n  }\n\n  rows.push({ json: row });\n}\n\nreturn rows;"
      },
