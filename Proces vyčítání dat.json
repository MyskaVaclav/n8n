    {
      "parameters": {
        "jsCode": "// HTML z GET /Login\nconst html = $json.data || $json.body;\n\n// vytáhnout antiforgery token z HTML\nconst tokenMatch = html.match(\n  /<input[^>]+name=\"__RequestVerificationToken\"[^>]+value=\"([^\"]+)\"/i\n);\n\nif (!tokenMatch) {\n  throw new Error('RequestVerificationToken NOT FOUND in HTML');\n}\n\nconst requestVerificationToken = tokenMatch[1];\n\n// vytáhnout cookies z response headers\nconst setCookies = $json.headers?.['set-cookie'];\n\nif (!Array.isArray(setCookies)) {\n  throw new Error('Set-Cookie headers NOT FOUND');\n}\n\n// vybrat jen důležité cookies\nconst cookieParts = setCookies\n  .filter(c =>\n    c.startsWith('.AspNetCore.Session=') ||\n    c.startsWith('.AspNetCore.Antiforgery.')\n  )\n  .map(c => c.split(';')[0]);\n\nif (cookieParts.length < 2) {\n  throw new Error('Missing Session or Antiforgery cookie');\n}\n\n// složit Cookie header \nconst cookieHeader = cookieParts.join('; ');\n\n// vrátit všechno připravené pro POST\nreturn [{\n  token: requestVerificationToken,\n  cookie: cookieHeader\n}];\n"
      },
