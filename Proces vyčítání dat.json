    {
      "parameters": {
        "jsCode": "// base cookies (Session + Antiforgery) z GET /Login code node\nconst baseCookie = $node[\"Extrakce antiforgery tokenu a cookies\"].json.cookie;\n\n// identity cookie z POST /Login response\nconst setCookies = $json.headers?.[\"set-cookie\"];\nif (!setCookies || !Array.isArray(setCookies)) {\n  throw new Error(\"No set-cookie on login response\");\n}\n\nconst identityCookie = setCookies\n  .map(c => c.split(\";\")[0])\n  .find(c => c.startsWith(\".AspNetCore.Identity.Application=\"));\n\nif (!identityCookie) {\n  throw new Error(\"Identity cookie not found - login failed\");\n}\n\n// ---- WINDOW INPUT FROM \"When Executed by Another Workflow\" ----\nlet windowStart = null;\nlet windowEnd = null;\n\ntry {\n  const triggerData = $node[\"When Executed by Another Workflow\"]?.json;\n  windowStart = triggerData?.windowStart ?? null;\n  windowEnd = triggerData?.windowEnd ?? null;\n} catch (e) {\n  // ignore if node not present in this execution path\n}\n\n// ---- If not provided → compute last completed :00 / :30 window ----\nif (!windowStart || !windowEnd) {\n  const now = new Date();\n  now.setSeconds(0, 0);\n\n  const minutes = now.getMinutes();\n  now.setMinutes(minutes < 30 ? 0 : 30, 0, 0);\n\n  const end = new Date(now);\n  const start = new Date(end.getTime() - 30 * 60 * 1000);\n\n  windowStart = start.toISOString();\n  windowEnd = end.toISOString();\n}\n\n// ---- FINAL OUTPUT ----\nreturn [{\n  cookie: `${baseCookie}; ${identityCookie}`,\n  windowStart,\n  windowEnd,\n}];"
      },
